generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  preferences Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions   StudySession[]
  cardStates UserCardState[]
  progress   UserProgress[]
}

model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  configKey   String  @unique
  icon        String?

  phases   Phase[]
  cards    Card[]
  sessions StudySession[]
  progress UserProgress[]
}

model Phase {
  id              String   @id @default(cuid())
  subjectId       String
  order           Int
  name            String
  description     String?
  prerequisiteIds String[]

  subject  Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  cards    Card[]
  progress UserProgress[]

  @@unique([subjectId, order])
}

model Card {
  id         String   @id @default(cuid())
  subjectId  String
  phaseId    String
  type       CardType
  front      Json
  back       Json
  tags       String[]
  difficulty Float    @default(0)
  createdAt  DateTime @default(now())

  subject    Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  phase      Phase           @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  userStates UserCardState[]
}

enum CardType {
  VOCABULARY
  PHRASE
  SCENARIO
  LISTENING
  CULTURAL
}

model UserCardState {
  id            String    @id @default(cuid())
  userId        String
  cardId        String
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lastReview    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  card    Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reviews ReviewLog[]

  @@unique([userId, cardId])
}

model ReviewLog {
  id              String   @id @default(cuid())
  userCardStateId String
  sessionId       String?
  rating          Int
  reviewedAt      DateTime @default(now())
  elapsedDays     Int
  scheduledDays   Int
  state           Int
  responseTimeMs  Int?

  userCardState UserCardState @relation(fields: [userCardStateId], references: [id], onDelete: Cascade)
  session       StudySession? @relation(fields: [sessionId], references: [id])
}

model StudySession {
  id           String      @id @default(cuid())
  userId       String
  subjectId    String
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  sessionType  SessionType
  cardsStudied Int         @default(0)
  correctCount Int         @default(0)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  reviews ReviewLog[]
}

enum SessionType {
  REVIEW
  NEW_CARDS
  VOICE_PRACTICE
  MIXED
}

model UserProgress {
  id            String    @id @default(cuid())
  userId        String
  subjectId     String
  phaseId       String?
  masteryScore  Float     @default(0)
  cardsLearned  Int       @default(0)
  totalCards    Int       @default(0)
  streak        Int       @default(0)
  lastStudiedAt DateTime?
  updatedAt     DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  phase   Phase?   @relation(fields: [phaseId], references: [id])

  @@unique([userId, subjectId, phaseId])
}
